# ──────────────────────────────────────────────────────────────
# Environment template — copy to `.env` and fill in your values.
# NEVER commit the real `.env` (it is git-ignored). See Docs/conventions.md §3.
# ──────────────────────────────────────────────────────────────

# --- Groq LLM (required) ---
# Get a free API key at https://console.groq.com (no credit card).
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# --- Embeddings (local, free; must match at ingest & query time) ---
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Vector store ---
CHROMA_DIR=./data/chroma
CHROMA_COLLECTION=mf_faq

# --- Retrieval tunables (SCORE_THRESHOLD is tuned empirically in Phase 3) ---
TOP_K=5
SCORE_THRESHOLD=0.65          # tuned in Phase 3/10 against the built index

# --- Output contract ---
MAX_SENTENCES=3

# --- CORS (comma-separated frontend origins) ---
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8501

# --- Misc ---
LOG_LEVEL=INFO

# --- In-app re-ingestion scheduler (optional; OFF by default) ---
# Only enable on an always-on host. Free hosts sleep when idle, so a timer
# there is unreliable; frequent scraping also risks anti-bot blocks.
SCHEDULER_ENABLED=0
INGEST_INTERVAL_HOURS=24
INGEST_RUN_ON_START=0
